{
  "name": "cetera-vue-utils",
  "version": "0.1.1",
  "description": "Vue 3 components, composables and utilities",
  "type": "module",
  "main": "./dist/cetera-vue-utils.umd.cjs",
  "module": "./dist/cetera-vue-utils.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/cetera-vue-utils.js",
      "require": "./dist/cetera-vue-utils.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "playground": "vite serve playground",
    "build": "vue-tsc --noEmit && vite build",
    "typecheck": "vue-tsc --noEmit",
    "release:patch": "npm version patch && npm run build && npm publish && git push --follow-tags",
    "release:minor": "npm version minor && npm run build && npm publish && git push --follow-tags",
    "release:major": "npm version major && npm run build && npm publish && git push --follow-tags"
  },
  "keywords": [
    "vue",
    "vue3",
    "components",
    "composables",
    "utils"
  ],
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "primevue": "^4.5.5",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.0.0",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  }
}
